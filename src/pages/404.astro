---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
---

<Layout
  title="Página no encontrada | LIVA Wellness"
  description="La página que buscás no existe. Volvé al inicio de LIVA Sueroterapia."
>
  <Navbar />
  <main class="min-h-[70vh] flex items-center justify-center px-4 py-20">
    <div class="text-center max-w-lg mx-auto">
      <!-- Icon -->
      <div class="flex justify-center mb-8">
        <div class="size-24 bg-primary/10 rounded-full flex items-center justify-center">
          <span
            class="material-symbols-outlined text-primary text-5xl"
            style="font-variation-settings: 'FILL' 0, 'wght' 200;"
          >search_off</span>
        </div>
      </div>

      <p class="text-primary font-bold tracking-widest uppercase text-xs mb-3">Error 404</p>
      <h1 class="text-4xl md:text-5xl font-black mb-4 tracking-tight">
        Página no encontrada
      </h1>
      <p class="text-slate-600 dark:text-slate-400 text-lg mb-10 leading-relaxed">
        La página que buscás no existe o fue movida. Volvé al inicio y encontrá todo sobre nuestros tratamientos.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/"
          class="bg-primary hover:bg-primary-hover text-white px-7 py-3.5 rounded-xl font-bold text-base transition-all duration-300 hover:scale-105 active:scale-95 hover:shadow-lg flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 0, 'wght' 400;">home</span>
          Volver al inicio
        </a>
        <a
          href="/#programas"
          class="border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark hover:border-primary text-slate-700 dark:text-slate-300 hover:text-primary px-7 py-3.5 rounded-xl font-bold text-base transition-all duration-300 hover:shadow-md"
        >
          Ver tratamientos
        </a>
      </div>
    </div>
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>
