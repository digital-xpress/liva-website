---
// DarkModeToggle - persists in localStorage under 'liva-theme'
---

<button
  id="dark-mode-toggle"
  aria-label="Cambiar modo de color"
  class="relative flex items-center justify-center w-10 h-10 rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary hover:border-primary dark:hover:border-primary transition-all duration-300 hover:scale-110 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
>
  <!-- Sun icon (light mode) -->
  <span
    id="icon-light"
    class="material-symbols-outlined absolute text-xl transition-all duration-300"
    style="font-variation-settings: 'FILL' 0, 'wght' 300;"
  >
    light_mode
  </span>
  <!-- Moon icon (dark mode) -->
  <span
    id="icon-dark"
    class="material-symbols-outlined absolute text-xl transition-all duration-300"
    style="font-variation-settings: 'FILL' 0, 'wght' 300;"
  >
    dark_mode
  </span>
</button>

<style>
  /* Icon visibility driven by JS-managed data attributes */
  #dark-mode-toggle[data-mode='light'] #icon-light {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  #dark-mode-toggle[data-mode='light'] #icon-dark {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }
  #dark-mode-toggle[data-mode='dark'] #icon-light {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }
  #dark-mode-toggle[data-mode='dark'] #icon-dark {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
</style>

<script>
  function syncToggle() {
    const btn = document.getElementById('dark-mode-toggle') as HTMLButtonElement | null;
    if (!btn) return;
    const isDark = document.documentElement.classList.contains('dark');
    btn.dataset.mode = isDark ? 'dark' : 'light';
  }

  function initDarkModeToggle() {
    const btn = document.getElementById('dark-mode-toggle') as HTMLButtonElement | null;
    if (!btn) return;

    syncToggle();

    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('liva-theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('liva-theme', 'dark');
      }
      syncToggle();
    });
  }

  initDarkModeToggle();
  document.addEventListener('astro:after-swap', initDarkModeToggle);
</script>
