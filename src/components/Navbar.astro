---
import DarkModeToggle from './DarkModeToggle.astro';

interface NavLink {
  href: string;
  label: string;
}

const navLinks: NavLink[] = [
  { href: '#programas', label: 'Programas' },
  { href: '#como-funciona', label: 'Cómo funciona' },
  { href: '#mendoza', label: 'Mendoza & Dalvian' },
  { href: '#seguridad', label: 'Seguridad' },
];

const CALENDLY_URL = 'https://calendly.com/liva-wellness';
---

<header
  id="navbar"
  class="sticky top-0 z-50 w-full border-b border-primary/10 transition-all duration-300"
  style="background: rgba(247,247,247,0.85); -webkit-backdrop-filter: blur(16px); backdrop-filter: blur(16px);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between gap-4">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group shrink-0">
        <span
          class="material-symbols-outlined text-primary text-3xl transition-transform duration-300 group-hover:scale-110"
          style="font-variation-settings: 'FILL' 0, 'wght' 300;"
        >fluid_med</span>
        <span class="text-xl font-bold tracking-tight text-primary">LIVA</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors duration-200 relative group"
          >
            {link.label}
            <span class="absolute -bottom-0.5 left-0 h-0.5 w-0 bg-primary transition-all duration-300 group-hover:w-full rounded-full"></span>
          </a>
        ))}
      </nav>

      <!-- Right actions -->
      <div class="flex items-center gap-3">
        <DarkModeToggle />

        <!-- Reservar button (desktop) -->
        <button
          id="nav-reservar-btn"
          data-calendly={CALENDLY_URL}
          class="hidden md:inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white px-5 py-2 rounded-lg text-sm font-bold transition-all duration-300 shadow-sm hover:shadow-md hover:scale-105 active:scale-95"
        >
          <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 0, 'wght' 400;">calendar_month</span>
          Reservar
        </button>

        <!-- Hamburger (mobile) -->
        <button
          id="mobile-menu-btn"
          aria-label="Abrir menú"
          aria-expanded="false"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface-dark text-slate-600 dark:text-slate-300 hover:text-primary transition-all duration-200"
        >
          <span id="hamburger-icon" class="material-symbols-outlined text-xl transition-all duration-300" style="font-variation-settings: 'FILL' 0, 'wght' 300;">menu</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 ease-out"
    style="max-height: 0; opacity: 0;"
  >
    <div class="max-w-7xl mx-auto px-4 pb-4 pt-2 flex flex-col gap-1 border-t border-primary/10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 py-3 rounded-lg hover:bg-primary/5 transition-all duration-200"
        >
          {link.label}
        </a>
      ))}
      <button
        id="mobile-reservar-btn"
        data-calendly={CALENDLY_URL}
        class="mt-2 flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white px-5 py-3 rounded-lg text-sm font-bold transition-all duration-200"
      >
        <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 0, 'wght' 400;">calendar_month</span>
        Reservar turno
      </button>
    </div>
  </div>
</header>

<style>
  /* Dark mode navbar background */
  :global(.dark) #navbar {
    background: rgba(25, 26, 24, 0.88) !important;
  }
  /* Scrolled state injected via JS */
  #navbar.scrolled {
    border-color: rgba(95, 108, 90, 0.15);
    box-shadow: 0 1px 20px rgba(0,0,0,0.08);
  }
</style>

<script>
  declare const Calendly: {
    initPopupWidget: (options: { url: string }) => void;
  };

  function openCalendly(url: string) {
    window.dispatchEvent(new CustomEvent('calendly:open'));
    if (typeof Calendly !== 'undefined') {
      Calendly.initPopupWidget({ url });
    } else {
      window.open(url, '_blank');
    }
  }

  function initNavbar() {
    // Scroll effect
    const navbar = document.getElementById('navbar');
    if (navbar) {
      const onScroll = () => {
        navbar.classList.toggle('scrolled', window.scrollY > 20);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Mobile menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu') as HTMLDivElement | null;
    const hamburgerIcon = document.getElementById('hamburger-icon');

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const isOpen = menuBtn.getAttribute('aria-expanded') === 'true';
        menuBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        if (isOpen) {
          mobileMenu.style.maxHeight = '0';
          mobileMenu.style.opacity = '0';
          if (hamburgerIcon) hamburgerIcon.textContent = 'menu';
        } else {
          mobileMenu.style.maxHeight = '400px';
          mobileMenu.style.opacity = '1';
          if (hamburgerIcon) hamburgerIcon.textContent = 'close';
        }
      });

      // Close on link click
      mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.style.maxHeight = '0';
          mobileMenu.style.opacity = '0';
          menuBtn.setAttribute('aria-expanded', 'false');
          if (hamburgerIcon) hamburgerIcon.textContent = 'menu';
        });
      });
    }

    // Calendly buttons
    const calendlyUrl = (document.getElementById('nav-reservar-btn') as HTMLButtonElement | null)?.dataset.calendly ?? '';
    document.getElementById('nav-reservar-btn')?.addEventListener('click', () => openCalendly(calendlyUrl));
    document.getElementById('mobile-reservar-btn')?.addEventListener('click', () => openCalendly(calendlyUrl));
  }

  initNavbar();
  document.addEventListener('astro:after-swap', initNavbar);
</script>
