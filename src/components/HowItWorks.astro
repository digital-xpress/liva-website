---
const steps = [
  {
    icon: 'quiz',
    number: '01',
    title: 'Wizard de Salud',
    description: 'Completá tu perfil inicial online para que entendamos tus objetivos y condición actual. Rápido, simple y confidencial.',
  },
  {
    icon: 'prescriptions',
    number: '02',
    title: 'Recomendación Médica',
    description: 'Nuestros expertos diseñan un plan personalizado basado en medicina funcional solo para vos. Sin protocolo genérico.',
  },
  {
    icon: 'home_health',
    number: '03',
    title: 'Sesión a Domicilio',
    description: 'Atención profesional en la privacidad de tu casa en Dalvian o cualquier zona de Mendoza. Cómodo y sin traslados.',
  },
];
---

<section class="py-20 lg:py-28 bg-slate-50 dark:bg-background-dark/60" id="como-funciona">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16 lg:mb-20 animate-on-scroll">
      <span class="inline-block text-primary font-bold tracking-widest uppercase text-xs mb-4">El proceso</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 tracking-tight">
        Tu camino al bienestar
      </h2>
      <p class="text-slate-600 dark:text-slate-400 text-lg max-w-xl mx-auto">
        Un proceso simple, profesional y adaptado a tus necesidades.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="stagger-group grid md:grid-cols-3 gap-8 lg:gap-10 relative">

      <!-- Connector line (desktop) -->
      <div
        class="hidden md:block absolute top-16 left-[calc(16.67%+2rem)] right-[calc(16.67%+2rem)] h-px"
        style="background: linear-gradient(90deg, transparent, rgba(95,108,90,0.2) 20%, rgba(95,108,90,0.2) 80%, transparent); pointer-events: none;"
        aria-hidden="true"
      ></div>

      {steps.map((step) => (
        <div class="stagger-item group relative bg-white dark:bg-surface-dark p-8 rounded-2xl border border-primary/5 dark:border-primary/10 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 text-center overflow-hidden">
          <!-- Shimmer effect on hover -->
          <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 pointer-events-none"
            style="background: linear-gradient(90deg, transparent, rgba(95,108,90,0.04), transparent);">
          </div>

          <!-- Step number -->
          <div class="absolute top-4 right-5 text-5xl font-black text-primary/5 dark:text-primary/10 select-none leading-none">
            {step.number}
          </div>

          <!-- Icon -->
          <div class="size-16 bg-primary/10 dark:bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-6 transition-transform duration-500 group-hover:scale-110">
            <span
              class="material-symbols-outlined text-primary text-3xl"
              style="font-variation-settings: 'FILL' 0, 'wght' 300;"
            >{step.icon}</span>
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors duration-300">
            {step.title}
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-14 animate-on-scroll">
      <p class="text-slate-500 dark:text-slate-400 text-sm mb-4">¿Querés saber más antes de empezar?</p>
      <a
        href="#seguridad"
        class="group inline-flex items-center gap-2 text-primary font-bold hover:underline underline-offset-4 transition-all duration-200"
      >
        Conocé nuestros protocolos de seguridad
        <span class="material-symbols-outlined text-sm transition-transform duration-300 group-hover:translate-x-1">arrow_forward</span>
      </a>
    </div>

  </div>
</section>
